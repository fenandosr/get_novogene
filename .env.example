# Novogene CSS America — credenciales
NOVOGENE_USERNAME=tu_usuario@empresa.com
NOVOGENE_PASSWORD=tu_password

# OAuth client (HZero defaults — cambiar si falla el login)
NOVOGENE_CLIENT_ID=client
NOVOGENE_CLIENT_SECRET=secret

# Token manual (fallback si el login automático falla)
# Obtener desde DevTools > Network > cualquier request > Authorization header
NOVOGENE_TOKEN=

# Sub-proyectos a monitorear (separados por coma)
# Formato: X202SCxxxxxxxx-Z01,X202SCxxxxxxxx-Z02,...
NOVOGENE_PROJECTS=X202SC25109710-Z01

# Días esperados para entrega (TAT threshold para alertas)
NOVOGENE_EXPECTED_TAT_DAYS=30

# Puerto del servidor web
SERVER_PORT=8080
